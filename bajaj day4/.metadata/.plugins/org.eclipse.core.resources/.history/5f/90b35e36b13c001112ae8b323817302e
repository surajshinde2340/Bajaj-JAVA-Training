package com.bajaj;

import java.util.ArrayList;

class GenericStack<T>{ 
	
	ArrayList<T> sp ;
	
    void push( T ele ) { 
    	sp.add(ele);
    }
    
   T pop( ){ 
	   if( sp.size() == 0 || sp == null ) { 
		   return null;
	   }
        T ele =  sp.get( sp.size() -1 );
        sp.remove( sp.size() -1);
        return ele;
       
    }
	
   
   
	GenericStack(  ){ 
		sp = new ArrayList<>();
	}
	
	
	
	
}

public class Main {

	public static void main(String[] args) {
		GenericStack<Integer> stack = new GenericStack();
		for( int i = 0; i<5; i++ ){ 
			stack.push( i );
		}
		
		for( int i = 0; i<5; i++ ){ 
			System.out.println( stack.pop() );
		}
		
		

	}

}
