package com.bajaj;


class Box<T>{ 
	T val;
	
	void set( T val ){ 
		this.val = val;
	}
	
	T get(){ 
		return val;
	}
	
	
}

public class Gen {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		
		Box<Integer> sp = new Box<>();
		sp.set( 100  );
		System.out.println(sp.get());
		
		
		Box t2 = new Box();
		System.out.println(  t2.get() );
	}

}
